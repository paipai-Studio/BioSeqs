  ref : String
  alt : Array[String]
  qual : Double?
  filter : Array[String]
  info : @hashmap.HashMap[String, String]
  format : Array[String]?
  samples : @hashmap.HashMap[String, Array[String]]
}
pub fn VcfRecord::get_genotype(Self, String) -> Array[String]?
pub fn VcfRecord::is_deletion(Self) -> Bool
pub fn VcfRecord::is_insertion(Self) -> Bool
pub fn VcfRecord::is_snp(Self) -> Bool

